{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npx pnpm@9 install --no-frozen-lockfile && npx pnpm@9 --filter @workspace/api-server run build"
  },
  "deploy": {
    "startCommand": "npx pnpm@9 --filter @workspace/api-server run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
